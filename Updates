            try {
                const data = JSON.parse(saved);
                document.getElementById('project-name').value = data.projectName || '';
                document.getElementById('location').value = data.location || '';
                document.getElementById('assessor-name').value = data.assessorName || '';
                document.getElementById('assessment-date').value = data.assessmentDate || '';
                document.getElementById('project-description').value = data.projectDescription || '';
                document.getElementById('project-purpose').value = data.projectPurpose || '';
                document.getElementById('flora-fauna').value = data.floraFauna || '';
                document.getElementById('soil-type').value = data.soilType || '';
                document.getElementById('waterways').value = data.waterways || '';
                document.getElementById('eco-distance').value = data.ecoDistance || 0;
                document.getElementById('infra-distance').value = data.infraDistance || 0;
                document.getElementById('land-use').value = data.landUse || '';
                document.getElementById('current-activities').value = data.currentActivities || '';
                document.getElementById('accessibility').value = data.accessibility || '';
                document.getElementById('project-area').value = data.projectArea || 1;
                if (data.riskValues) {
                    RISK_METRICS.forEach((m, i) => {
                        const slider = document.getElementById(`slider-${m.id}`);
                        if (slider && data.riskValues[i]) {
                            slider.value = data.riskValues[i];
