        function deleteStakeholder(id) { stakeholders = stakeholders.filter(s => s.id !== id); renderStakeholders(); saveToLocalStorage(); showNotification('Stakeholder removed', 'success'); }
        function updateStakeholderProgress() {
            const confirmed = stakeholders.filter(s => s.status === 'Confirmed').length;
            const percent = stakeholders.length > 0 ? Math.round((confirmed / stakeholders.length) * 100) : 0;
            const bar = document.getElementById('stakeholder-progress');
            const text = document.getElementById('stakeholder-progress-text');
            bar.style.width = `${percent}%`;
            bar.textContent = `${percent}%`;
            text.textContent = `Stakeholder engagement: ${percent}% confirmed (${confirmed}/${stakeholders.length})`;
        }

