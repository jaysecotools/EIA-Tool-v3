        function renderTimeline() {
            const container = document.getElementById('timeline-container');
            if (milestones.length === 0) { container.innerHTML = '<p>No milestones added.</p>'; return; }
            container.innerHTML = milestones.map((m, i) => `
                <div class="timeline-item">
                    <h4>${m.name}</h4>
                    <input type="date" value="${m.date}" onchange="updateMilestoneDate(${i}, this.value)" style="width:160px;">
                    ${m.editable ? `<button class="btn btn-sm btn-danger" onclick="deleteMilestone(${i})">Delete</button>` : '<span style="font-size:0.75rem; color:var(--text-gray);">Default</span>'}
                </div>
            `).join('');
        }

        function addMilestone() {
            const name = document.getElementById('milestone-name').value.trim();
            const date = document.getElementById('milestone-date').value;
            if (!name) { showNotification('Please enter a milestone name', 'error'); return; }
            milestones.push({ name, date, editable: true });
            renderTimeline();
            document.getElementById('milestone-name').value = '';
            document.getElementById('milestone-date').value = '';
            showNotification('Milestone added', 'success');
            saveToLocalStorage();
        }

        function updateMilestoneDate(index, date) { milestones[index].date = date; renderTimeline(); saveToLocalStorage(); }
        function deleteMilestone(index) { milestones.splice(index, 1); renderTimeline(); saveToLocalStorage(); showNotification('Milestone deleted', 'success'); }

        function addStakeholder() {
            const role = document.getElementById('stakeholder-role').value.trim();
            const status = document.getElementById('stakeholder-status').value;
            const email = document.getElementById('stakeholder-email').value.trim();
            const phone = document.getElementById('stakeholder-phone').value.trim();
            const comments = document.getElementById('stakeholder-comments').value.trim();
            if (!role) { showNotification('Please enter a stakeholder role', 'error'); return; }
            stakeholders.push({ id: Date.now(), role, status, email, phone, comments, dateAdded: new Date().toISOString() });
            renderStakeholders();
            document.getElementById('stakeholder-role').value = '';
            document.getElementById('stakeholder-email').value = '';
            document.getElementById('stakeholder-phone').value = '';
            document.getElementById('stakeholder-comments').value = '';
            showNotification('Stakeholder added', 'success');
            saveToLocalStorage();
        }

        function renderStakeholders() {
            const container = document.getElementById('stakeholder-list');
            if (stakeholders.length === 0) { container.innerHTML = '<p style="color:var(--text-gray); text-align:center;">No stakeholders added yet.</p>'; updateStakeholderProgress(); return; }
            container.innerHTML = `<div class="stakeholder-grid">${stakeholders.map(s => `
