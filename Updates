                if (data.stakeholders) stakeholders = data.stakeholders;
                if (data.milestones) milestones = data.milestones;
                if (data.selectedBioregion) {
                    const br = TAS_BIOREGIONS.find(b => b.name === data.selectedBioregion);
                    if (br) selectBioregion(br.name, br.multiplier);
                }
                // Load map data
                if (data.mapData && data.mapData.lat && data.mapData.lng) {
                    setTimeout(() => {
                        setMarker(data.mapData.lat, data.mapData.lng);
                        if (data.mapData.address) {
                            markerAddress = data.mapData.address;
                            document.getElementById('address-display').textContent = data.mapData.address;
                            document.getElementById('location').value = data.mapData.address;
                        }
                    }, 800);
                }
                renderStakeholders();
                renderTimeline();
                updateAllCalculations();
                showNotification('Previous session loaded', 'success');
            } catch (e) { console.error('Failed to load saved data:', e); }
        }

        function loadFromLocalStorage() { loadSavedData(); }

        function saveToCSV() {
            const riskValues = RISK_METRICS.map(m => document.getElementById(`slider-${m.id}`).value).join(';');
            const activities = Array.from(document.querySelectorAll('#activities-container input:checked')).map(cb => cb.value).join(';');
            const score = calculateTotalRisk();
            const riskLevel = getRiskLevel(score).level;
            const mapData = getMapData();
            const rows = [
                ['Section','Field','Value'],
                ['Project','Project Name', document.getElementById('project-name').value || 'N/A'],
                ['Project','Location', document.getElementById('location').value || 'N/A'],
                ['Project','Assessor', document.getElementById('assessor-name').value || 'N/A'],
                ['Project','Assessment Date', document.getElementById('assessment-date').value || 'N/A'],
                ['Tasmania','Bioregion', selectedBioregion || 'Not selected'],
                ['Risk','Overall Score', score],
                ['Risk','Risk Level', riskLevel],
                ['Risk','Detailed Metrics', riskValues],
                ['Activities','Selected Activities', activities],
                ['Budget','Project Area (ha)', document.getElementById('project-area').value || '1'],
                ['Stakeholders','Total', stakeholders.length],
                ['Stakeholders','Confirmed', stakeholders.filter(s => s.status === 'Confirmed').length],
                ['Milestones','Total', milestones.length],
                ['Map','Latitude', mapData ? mapData.lat : 'N/A'],
                ['Map','Longitude', mapData ? mapData.lng : 'N/A'],
                ['Map','Address', mapData ? mapData.address : 'N/A']
            ];
            const csvContent = rows.map(row => row.map(cell => `"${String(cell).replace(/"/g,'""')}"`).join(',')).join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `EIA_Assessment_${new Date().toISOString().slice(0,10)}.csv`;
            link.click();
            URL.revokeObjectURL(url);
            showNotification('Data exported to CSV', 'success');
        }

        function loadFromCSV(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                const lines = e.target.result.split('\n');
                for (let i = 1; i < lines.length; i++) {
                    const parts = lines[i].split(/,(?=(?:(?:[^"]*"){2})*[^"]*$)/);
                    if (parts.length >= 3) {
                        const field = parts[1].replace(/^"|"$/g, '');
                        const value = parts[2].replace(/^"|"$/g, '');
                        const map = { 'Project Name': 'project-name', 'Location': 'location', 'Assessor': 'assessor-name', 'Assessment Date': 'assessment-date', 'Project Area (ha)': 'project-area' };
                        const elId = map[field];
                        if (elId && document.getElementById(elId)) document.getElementById(elId).value = value;
                    }
                }
                updateAllCalculations();
                showNotification('Data loaded from CSV', 'success');
            };
            reader.readAsText(file);
            input.value = '';
        }

        // ============================================
        // PROFESSIONAL PDF GENERATION WITH MAP
        // ============================================
        function generatePDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF('p', 'mm', 'a4');
            const pageWidth = doc.internal.pageSize.width;
            const margin = 20;
            let y = margin;
            
            function sanitize(text) {
                if (typeof text !== 'string') return 'N/A';
                return text.replace(/[^\w\s.,;:!?()\-'"&@\/\\[\]{}<>+=*~%#| ]/g, '').trim() || 'N/A';
            }
            
            function addText(text, x, y, fontSize = 10, maxWidth = pageWidth - margin * 2) {
                doc.setFontSize(fontSize);
                doc.setTextColor(0, 0, 0);
                const lines = doc.splitTextToSize(sanitize(text), maxWidth);
                doc.text(lines, x, y);
                return y + lines.length * (fontSize * 0.45);
            }
            
            function addHeading(text, y, fontSize = 14) {
                doc.setFontSize(fontSize);
                doc.setTextColor(30, 90, 62);
                doc.setFont('helvetica', 'bold');
                const lines = doc.splitTextToSize(sanitize(text), pageWidth - margin * 2);
                doc.text(lines, margin, y);
                doc.setFont('helvetica', 'normal');
                return y + (fontSize === 14 ? 10 : 7);
            }
            
            function addDivider(y) {
                doc.setDrawColor(30, 90, 62);
                doc.setLineWidth(0.5);
                doc.line(margin, y, pageWidth - margin, y);
                return y + 6;
            }
            
            function checkPage(y, needed = 15) {
                if (y > doc.internal.pageSize.height - margin - needed) {
                    doc.addPage();
                    return margin;
                }
                return y;
            }

            // ===== TITLE PAGE =====
            doc.setFontSize(28);
            doc.setTextColor(30, 90, 62);
            doc.setFont('helvetica', 'bold');
            const titleLines = doc.splitTextToSize('Tasmanian Environmental Impact Assessment Report', pageWidth - margin * 2);
            doc.text(titleLines, margin, y);
            y += titleLines.length * 8 + 10;
            
            doc.setFontSize(16);
            doc.setTextColor(60, 60, 60);
            doc.setFont('helvetica', 'normal');
            const subLines = doc.splitTextToSize('Professional Assessment Report', pageWidth - margin * 2);
            doc.text(subLines, margin, y);
            y += subLines.length * 6 + 15;
            
            const projName = sanitize(document.getElementById('project-name').value || 'Unnamed Project');
            doc.setFontSize(14);
            doc.setTextColor(0, 0, 0);
            doc.text(`Project: ${projName}`, margin, y);
            y += 8;
            doc.text(`Assessor: ${sanitize(document.getElementById('assessor-name').value || 'Not specified')}`, margin, y);
            y += 8;
            doc.text(`Date: ${sanitize(document.getElementById('assessment-date').value || new Date().toLocaleDateString())}`, margin, y);
            y += 8;
            doc.text(`Location: ${sanitize(document.getElementById('location').value || 'Not specified')}`, margin, y);
            y += 15;
            
            doc.setFontSize(10);
            doc.setTextColor(100, 100, 100);
            doc.text(`Generated: ${new Date().toLocaleString()}`, margin, y);
            y += 20;
            
            // ===== MAP PAGE =====
            const mapData = getMapData();
            if (mapData) {
                doc.addPage();
                y = margin;
                y = addHeading('Project Location Map', y, 16);
                y = addDivider(y);
                doc.setFontSize(11);
                doc.setTextColor(0,0,0);
                y = addText(`Coordinates: ${mapData.lat.toFixed(6)}, ${mapData.lng.toFixed(6)}`, margin, y, 11);
                y += 4;
                y = addText(`Address: ${sanitize(mapData.address || 'Location on map')}`, margin, y, 11);
                y += 8;
                
                // Draw a simple map representation
                doc.setDrawColor(200, 200, 200);
                doc.setFillColor(240, 248, 240);
                doc.rect(margin, y, pageWidth - margin * 2, 80, 'FD');
                doc.setDrawColor(30, 90, 62);
                doc.setLineWidth(1);
                doc.rect(margin, y, pageWidth - margin * 2, 80);
                
                // Draw a marker symbol
                doc.setFillColor(200, 50, 50);
                doc.circle(pageWidth / 2, y + 40, 6, 'F');
                doc.setFillColor(255, 255, 255);
                doc.circle(pageWidth / 2, y + 40, 3, 'F');
                
                // Label
                doc.setFontSize(9);
                doc.setTextColor(60, 60, 60);
                doc.text('● Project Location (approximate)', pageWidth / 2 - 40, y + 70);
                
                y += 90;
                
                // Add map disclaimer
                doc.setFontSize(8);
                doc.setTextColor(150, 150, 150);
                doc.text('Map data © OpenStreetMap contributors. Location is approximate.', margin, y);
                y += 10;
            }

            // ===== CONTENT PAGES =====
            // 1. Project Details
            doc.addPage();
            y = margin;
            y = addHeading('1. Project Details', y, 14);
            y = addDivider(y);
            doc.setFontSize(10);
            doc.setTextColor(0,0,0);
            y = addText(`Project Name: ${sanitize(document.getElementById('project-name').value)}`, margin, y, 10);
