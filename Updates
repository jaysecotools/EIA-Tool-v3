                    ${s.email ? `<p><strong>Email:</strong> ${escapeHtml(s.email)}</p>` : ''}
                    ${s.phone ? `<p><strong>Phone:</strong> ${escapeHtml(s.phone)}</p>` : ''}
                    ${s.comments ? `<p><strong>Comments:</strong> ${escapeHtml(s.comments)}</p>` : ''}
