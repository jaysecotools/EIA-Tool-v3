            TAS_LEGISLATION_SUMMARY.slice(0, 5).forEach(leg => {
                y = addText(`• ${leg.name}: ${leg.description.substring(0, 60)}...`, margin + 5, y, 9);
                y = checkPage(y, 15);
            });
            y += 4;
            
            // ===== APPLY FOOTERS =====
            const totalPages = doc.internal.getNumberOfPages();
            for (let i = 1; i <= totalPages; i++) {
                doc.setPage(i);
                doc.setFontSize(8);
                doc.setTextColor(150, 150, 150);
                doc.setFont('helvetica', 'normal');
                const footerText = `Tasmanian EIA Report - Page ${i} of ${totalPages} - Professional Assessment`;
                doc.text(footerText, margin, doc.internal.pageSize.height - 10);
            }
            
            const filename = `Tasmania_EIA_Report_${sanitize(document.getElementById('project-name').value || 'project')}_${new Date().toISOString().slice(0,10)}.pdf`;
            doc.save(filename);
            showNotification('Professional PDF report generated with map location', 'success');
        }

        // ============================================
        // RESET & HELPERS
        // ============================================
        function resetAllData() {
            if (!confirm('⚠️ WARNING: This will permanently delete ALL data. Are you sure?')) return;
            document.querySelectorAll('input, textarea, select').forEach(el => {
                if (el.type === 'checkbox') el.checked = false;
                else if (el.type === 'range') el.value = '0';
                else if (el.tagName === 'SELECT') el.selectedIndex = 0;
                else if (el.type !== 'file' && el.id !== 'assessment-date') el.value = '';
            });
            document.getElementById('assessment-date').valueAsDate = new Date();
            RISK_METRICS.forEach(m => {
                document.getElementById(`value-${m.id}`).textContent = '0';
                updateResultIndicator(m.id, 0);
            });
            stakeholders = [];
            milestones = milestones.filter(m => !m.editable);
            selectedBioregion = null; currentMultiplier = 1.0;
            document.querySelectorAll('.bioregion-btn').forEach(b => b.classList.remove('selected'));
            document.getElementById('selected-bioregion-info').innerHTML = '';
            document.getElementById('bioregion-risk-impact').innerHTML = '';
            document.getElementById('offsets-result').style.display = 'none';
            // Clear map
            clearMarker();
            localStorage.removeItem('eia_assessment_complete');
            renderStakeholders();
            renderTimeline();
            updateAllCalculations();
            showNotification('All data reset', 'info');
        }

        function submitFeedback() {
            const feedback = document.getElementById('user-feedback').value.trim();
            if (!feedback) { showNotification('Please enter your feedback', 'error'); return; }
            console.log('Feedback:', feedback);
            showNotification('Thank you for your feedback!', 'success');
            document.getElementById('user-feedback').value = '';
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : '&gt;');
        }

        function showNotification(message, type = 'info') {
            const el = document.createElement('div');
            el.className = 'notification';
            const colors = { success: '#2a6f4b', error: '#c84f43', info: '#4a90e2' };
            el.style.background = colors[type] || colors.info;
            el.textContent = message;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 3000);
        }

        function toggleCard(header) {
            const content = header.nextElementSibling;
            header.classList.toggle('collapsed');
            content.classList.toggle('collapsed');
        }
    </script>
</body>
</html>
