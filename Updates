        function updateEPBCReferral() {
            const container = document.getElementById('epbc-container');
            if (!container) return;
            const riskScore = calculateTotalRisk();
            const biodiversityRisk = parseFloat(document.getElementById(`slider-biodiversity`)?.value) || 0;
            const habitatRisk = parseFloat(document.getElementById(`slider-habitat`)?.value) || 0;
            const vegetationRisk = parseFloat(document.getElementById(`slider-vegetation`)?.value) || 0;
            let needsReferral = false;
            let reasons = [];
            if (biodiversityRisk > 60 || habitatRisk > 60) { needsReferral = true; reasons.push('Threatened species/habitat impact exceeds threshold'); }
            if (vegetationRisk > 70) { needsReferral = true; reasons.push('Significant native vegetation clearance'); }
            if (riskScore > 70 && selectedBioregion && (selectedBioregion === 'Central Highlands' || selectedBioregion === 'West Coast')) {
                needsReferral = true; reasons.push('High risk in high-conservation bioregion');
