        // ============================================
        // MAP FUNCTIONS
        // ============================================
        function initMap() {
            if (mapInitialized) return;
            
            const container = document.getElementById('map-container');
            if (!container) return;
            
            // Default to Tasmania center
            const defaultLat = -42.0;
            const defaultLng = 146.5;
            
            map = L.map('map-container').setView([defaultLat, defaultLng], 7);
            
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
            }).addTo(map);
            
            // Click to drop marker
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;
                setMarker(lat, lng);
                // Reverse geocode
                reverseGeocode(lat, lng);
            });
            
            mapInitialized = true;
            
            // Load saved marker from localStorage
            const savedMarker = localStorage.getItem('eia_map_marker');
            if (savedMarker) {
                try {
                    const data = JSON.parse(savedMarker);
                    if (data.lat && data.lng) {
                        setMarker(data.lat, data.lng);
                        if (data.address) {
                            markerAddress = data.address;
                            document.getElementById('address-display').textContent = data.address;
                        }
                        // Update location field
                        if (data.address) {
                            document.getElementById('location').value = data.address;
                        } else if (data.lat && data.lng) {
                            document.getElementById('location').value = `${data.lat}, ${data.lng}`;
                        }
                    }
                } catch(e) {}
            }
        }

        function setMarker(lat, lng) {
            if (!map) return;
            
            markerLat = lat;
            markerLng = lng;
            
            if (marker) {
                map.removeLayer(marker);
            }
            
            marker = L.marker([lat, lng], {
                draggable: true
            }).addTo(map);
            
            marker.on('dragend', function(e) {
                const pos = marker.getLatLng();
                markerLat = pos.lat;
                markerLng = pos.lng;
                updateCoordDisplay();
                reverseGeocode(pos.lat, pos.lng);
                saveMarkerToStorage();
            });
            
            map.setView([lat, lng], 14);
            updateCoordDisplay();
            saveMarkerToStorage();
        }

        function updateCoordDisplay() {
            if (markerLat !== null && markerLng !== null) {
                document.getElementById('coord-display').textContent = `${markerLat.toFixed(6)}, ${markerLng.toFixed(6)}`;
                // Update location field
                const address = document.getElementById('address-display').textContent;
                if (address && address !== 'None') {
                    document.getElementById('location').value = address;
                } else {
                    document.getElementById('location').value = `${markerLat.toFixed(6)}, ${markerLng.toFixed(6)}`;
                }
            }
        }

        function reverseGeocode(lat, lng) {
            const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`;
            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data && data.display_name) {
                        markerAddress = data.display_name;
                        document.getElementById('address-display').textContent = data.display_name;
                        document.getElementById('location').value = data.display_name;
                        saveMarkerToStorage();
                    }
                })
                .catch(() => {
                    // Silently fail - coordinates still work
                });
        }

        function searchAddress() {
            const query = document.getElementById('address-search').value.trim();
            if (!query) {
                showNotification('Please enter an address to search', 'error');
                return;
            }
            
            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`;
            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data && data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lng = parseFloat(data[0].lon);
                        setMarker(lat, lng);
                        markerAddress = data[0].display_name;
                        document.getElementById('address-display').textContent = data[0].display_name;
                        document.getElementById('location').value = data[0].display_name;
                        saveMarkerToStorage();
                        showNotification('Location found!', 'success');
                    } else {
                        showNotification('Address not found', 'error');
                    }
                })
                .catch(() => {
                    showNotification('Search failed. Please try again.', 'error');
                });
        }

        function useMyLocation() {
            if (!navigator.geolocation) {
                showNotification('Geolocation is not supported by your browser', 'error');
                return;
            }
            
            showNotification('Getting your location...', 'info');
            navigator.geolocation.getCurrentPosition(
                function(position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    setMarker(lat, lng);
                    reverseGeocode(lat, lng);
                    showNotification('Location found!', 'success');
                },
                function(error) {
                    showNotification('Unable to get your location. Please check permissions.', 'error');
                    console.error('Geolocation error:', error);
                },
                { enableHighAccuracy: true, timeout: 10000 }
            );
        }

        function dropMarkerAtCenter() {
            if (!map) return;
            const center = map.getCenter();
            setMarker(center.lat, center.lng);
            reverseGeocode(center.lat, center.lng);
            showNotification('Marker dropped at map center', 'success');
        }

        function clearMarker() {
            if (marker) {
                map.removeLayer(marker);
                marker = null;
            }
            markerLat = null;
            markerLng = null;
            markerAddress = '';
            document.getElementById('coord-display').textContent = 'None set';
            document.getElementById('address-display').textContent = 'None';
            localStorage.removeItem('eia_map_marker');
            showNotification('Marker cleared', 'info');
        }

        function saveMarkerToStorage() {
            if (markerLat !== null && markerLng !== null) {
                const data = {
                    lat: markerLat,
                    lng: markerLng,
                    address: markerAddress || document.getElementById('address-display').textContent
                };
                localStorage.setItem('eia_map_marker', JSON.stringify(data));
            }
        }

        function getMapData() {
            if (markerLat !== null && markerLng !== null) {
