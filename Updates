        function calculateTotalRisk() {
            let total = 0;
            RISK_METRICS.forEach(m => { const v = parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0; total += v * m.weight; });
            return Math.round(total);
        }

        function getRiskLevel(score) {
            if (score <= 30) return { level: 'Low Risk', class: 'risk-low', color: '#6ba583' };
            if (score <= 60) return { level: 'Moderate Risk', class: 'risk-moderate', color: '#f0c75e' };
            return { level: 'High Risk', class: 'risk-high', color: '#c84f43' };
        }

        function updateAllCalculations() {
            updateRiskDisplay();
            updateCharts();
            updateRecommendations();
            updateProgress();
            updateBudget();
            updateRiskComparison();
            updateProjections();
            renderCompliance();
            updateEPBCReferral();
        }

        function updateRiskDisplay() {
            const score = calculateTotalRisk();
            const risk = getRiskLevel(score);
            const display = document.getElementById('risk-display');
            display.textContent = `Overall Risk: ${risk.level} (${score}%)${selectedBioregion ? ` | Bioregion: ${selectedBioregion} (${currentMultiplier}x)` : ''}`;
            display.className = `risk-display ${risk.class}`;
        }

        function updateCharts() {
            const data = RISK_METRICS.map(m => parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0);
            if (radarChart) radarChart.data.datasets[0].data = data;
            if (barChart) barChart.data.datasets[0].data = data;
            if (radarChart) radarChart.update();
            if (barChart) barChart.update();
        }

        function updateRecommendations() {
            const recs = [];
            RISK_METRICS.forEach(m => {
                const v = parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0;
                if (v > 80) recs.push({ metric: m.label, level: 'high', msg: `URGENT: ${m.label.replace(/[^a-zA-Z\s]/g,'').trim()} requires immediate intervention.` });
                else if (v > 60) recs.push({ metric: m.label, level: 'medium', msg: `${m.label.replace(/[^a-zA-Z\s]/g,'').trim()} shows elevated levels. Develop mitigation strategy.` });
                else if (v > 40) recs.push({ metric: m.label, level: 'medium', msg: `Monitor ${m.label.replace(/[^a-zA-Z\s]/g,'').trim()} levels. Consider preventive measures.` });
                else if (v > 20) recs.push({ metric: m.label, level: 'low', msg: `${m.label.replace(/[^a-zA-Z\s]/g,'').trim()} within acceptable range. Continue monitoring.` });
            });
            if (selectedBioregion && selectedBioregion !== "Northern Slopes") {
                recs.push({ metric: "Bioregion Alert", level: 'medium', msg: `Project located in ${selectedBioregion}. Enhanced controls may be required.` });
            }
            const container = document.getElementById('recommendations-container');
            if (recs.length === 0) { container.innerHTML = '<p style="color:var(--primary);">✓ All impacts within acceptable limits.</p>'; return; }
            container.innerHTML = recs.slice(0, 5).map(r => `
                <div class="recommendation-item recommendation-${r.level}">
                    <strong>${r.metric.replace(/[^a-zA-Z\s]/g,'').trim()}:</strong> ${r.msg}
                </div>
            `).join('');
        }

        function updateProgress() {
            let completed = 0;
            RISK_METRICS.forEach(m => { if (parseFloat(document.getElementById(`slider-${m.id}`)?.value) > 0) completed++; });
            const percent = Math.round((completed / RISK_METRICS.length) * 100);
            const bar = document.getElementById('progress-bar');
            const text = document.getElementById('progress-text');
            bar.style.width = `${percent}%`;
            bar.textContent = `${percent}%`;
            text.textContent = `Risk assessment: ${percent}% (${completed}/${RISK_METRICS.length} metrics)`;
        }

        function updateBudget() {
            const area = parseFloat(document.getElementById('project-area')?.value) || 1;
            let total = 0; let items = [];
            RISK_METRICS.forEach(m => {
                const v = parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0;
                const cost = v * 75 * area * currentMultiplier;
                total += cost;
                if (v > 0) items.push(`<div class="budget-item"><span>${m.label.replace(/[^a-zA-Z\s]/g,'').trim()}</span><span>$${Math.round(cost).toLocaleString()}</span></div>`);
            });
            const container = document.getElementById('budget-container');
            container.innerHTML = `
                ${items.length > 0 ? items.join('') : '<p style="color:var(--text-gray);">Adjust risk sliders to see cost estimates</p>'}
                <div class="budget-total"><span>Total Estimated Cost:</span><span style="color:var(--primary);">$${Math.round(total).toLocaleString()}</span></div>
                <p style="font-size:0.75rem; color:var(--text-gray); margin-top:0.5rem;">* Based on ${area} ha, risk levels${selectedBioregion ? `, ${selectedBioregion} (${currentMultiplier}x)` : ''}</p>
            `;
        }

        function updateRiskComparison() {
            const currentData = RISK_METRICS.map(m => parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0);
            if (!previousRiskData) previousRiskData = currentData.map(() => Math.floor(Math.random() * 30));
            const container = document.getElementById('risk-comparison');
            let html = '<h4 style="margin-bottom:1rem;">Comparison with Previous Assessment</h4>';
            RISK_METRICS.forEach((m, i) => {
                const cur = currentData[i], prev = previousRiskData[i], diff = cur - prev;
                const trend = diff > 0 ? '↑ Increase' : diff < 0 ? '↓ Decrease' : '→ Stable';
                const color = diff > 0 ? 'var(--danger)' : diff < 0 ? 'var(--primary)' : 'var(--text-gray)';
                html += `<div style="display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px solid var(--border);">
                    <span>${m.label.replace(/[^a-zA-Z\s]/g,'').trim()}</span>
                    <span>Previous: ${prev}%</span>
                    <span>Current: ${cur}%</span>
                    <span style="color:${color};">${trend} (${Math.abs(diff)}%)</span>
                </div>`;
            });
            container.innerHTML = html;
            previousRiskData = [...currentData];
        }

        function updateProjections() {
            const container = document.getElementById('projections-container');
            let html = '<h4 style="margin-bottom:1rem;">10-Year Impact Projections (Without Mitigation)</h4>';
            RISK_METRICS.forEach(m => {
                const cur = parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0;
                const p5 = Math.min(100, Math.round(cur * 1.3));
                const p10 = Math.min(100, Math.round(cur * 1.6));
                const p20 = Math.min(100, Math.round(cur * 2.2));
                html += `
                    <div style="margin-bottom:1rem; padding:0.75rem; background:#f9fafb; border-radius:8px;">
                        <strong>${m.label.replace(/[^a-zA-Z\s]/g,'').trim()}</strong>
                        <div style="display:flex; gap:1rem; margin-top:0.5rem; font-size:0.875rem; flex-wrap:wrap;">
                            <span>Current: ${cur}%</span>
                            <span>→ 5 Yr: ${p5}%</span>
                            <span>→ 10 Yr: ${p10}%</span>
                            <span>→ 20 Yr: ${p20}%</span>
                        </div>
                        <div class="progress-container" style="margin-top:0.5rem; height:6px;">
                            <div class="progress-bar" style="width:${p20}%; background:var(--danger);"></div>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        function renderCompliance() {
            const container = document.getElementById('compliance-container');
            if (!container) return;
            const riskValues = {};
            RISK_METRICS.forEach(m => { riskValues[m.id] = parseFloat(document.getElementById(`slider-${m.id}`)?.value) || 0; });
            const updatedPolicies = POLICIES.map(p => {
                let status = p.status;
                if (p.criteria && p.criteria.length > 0) {
                    const relevantRisks = p.criteria.map(c => riskValues[c] || 0);
                    const maxRisk = Math.max(...relevantRisks, 0);
                    if (maxRisk > 70) status = "Non-Compliant";
                    else if (maxRisk > 50) status = "Partial";
                    else if (maxRisk > 30) status = "Under Review";
                    else if (maxRisk > 0) status = "Compliant";
                }
                return { ...p, status };
            });
            let compliantCount = 0, partialCount = 0, nonCompliantCount = 0;
            container.innerHTML = updatedPolicies.map(p => {
                let statusClass = '';
                switch(p.status) {
                    case 'Compliant': statusClass = 'status-compliant'; compliantCount++; break;
                    case 'Partial': case 'In Progress': statusClass = 'status-partial'; partialCount++; break;
                    case 'Non-Compliant': statusClass = 'status-non-compliant'; nonCompliantCount++; break;
                    default: statusClass = 'status-review'; partialCount++;
                }
                return `<div class="compliance-item">
                    <div style="flex:1;"><strong>${p.name}</strong><p style="font-size:0.75rem; color:var(--text-gray); margin-top:0.25rem;">${p.description}</p></div>
                    <div style="text-align:right;">
                        <span class="compliance-status ${statusClass}">${p.status}</span><br>
                        <a href="${p.reference}" target="_blank" class="compliance-link">View Standard →</a>
                    </div>
                </div>`;
            }).join('');
            const totalPolicies = updatedPolicies.filter(p => p.status !== 'Not Applicable').length;
            const score = Math.round((compliantCount / totalPolicies) * 100);
            let scoreColor = '', scoreMessage = '';
            if (score >= 80) { scoreColor = 'var(--primary)'; scoreMessage = 'Excellent - All major requirements met'; }
            else if (score >= 60) { scoreColor = 'var(--warning)'; scoreMessage = 'Good - Some areas need attention'; }
            else { scoreColor = 'var(--danger)'; scoreMessage = 'Action Required - Multiple compliance gaps identified'; }
            document.getElementById('compliance-score').innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
                    <div><span style="font-size:1.25rem;">Overall Compliance Score: <span style="color:${scoreColor};">${score}%</span></span>
                    <p style="font-size:0.875rem; margin-top:0.25rem;">${scoreMessage}</p></div>
                    <div style="display:flex; gap:1rem;">
                        <span style="color:var(--primary);">✓ Compliant: ${compliantCount}</span>
                        <span style="color:var(--warning);">⚠️ Partial: ${partialCount}</span>
                        <span style="color:var(--danger);">✗ Non-Compliant: ${nonCompliantCount}</span>
                    </div>
                </div>
            `;
        }

