        function calculateOffsets() {
            const area = parseFloat(document.getElementById('clear-area').value) || 0;
            const vegType = document.getElementById('veg-type').value;
            const threatenedFactor = parseFloat(document.getElementById('threatened-species-select').value);
            let multiplier = 1; let vegDescription = '';
            switch(vegType) {
                case 'low': multiplier = 2; vegDescription = 'Low Conservation Value'; break;
                case 'medium': multiplier = 5; vegDescription = 'Medium Conservation Value'; break;
                case 'high': multiplier = 10; vegDescription = 'High Conservation Value'; break;
                case 'critical': multiplier = 15; vegDescription = 'Critical / TEC'; break;
                default: multiplier = 2;
            }
            const totalMultiplier = multiplier * (1 + threatenedFactor) * currentMultiplier;
            const offsetHectares = area * totalMultiplier;
            const estimatedCost = offsetHectares * 25000;
            const result = document.getElementById('offsets-result');
            result.style.display = 'block';
            result.innerHTML = `
                <div class="offsets-result">
                    <h4 style="color:var(--primary); margin-bottom:1rem;">📊 Biodiversity Offsets Calculation</h4>
                    <div style="display:grid; gap:0.75rem;">
                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><strong>Area to be cleared:</strong> <span>${area.toFixed(2)} ha</span></div>
                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><strong>Vegetation type:</strong> <span>${vegDescription}</span></div>
                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><strong>Base multiplier:</strong> <span>${multiplier}:1</span></div>
                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><strong>Threatened species factor:</strong> <span>+${(threatenedFactor * 100)}%</span></div>
                        ${selectedBioregion ? `<div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><strong>Bioregion multiplier:</strong> <span>${currentMultiplier}x (${selectedBioregion})</span></div>` : ''}
                        <div style="padding-top:0.75rem; border-top:2px solid var(--border); display:flex; justify-content:space-between; flex-wrap:wrap; font-weight:bold;"><span>Total offset required:</span> <span style="color:var(--primary);">${offsetHectares.toFixed(2)} ha</span></div>
                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap;"><span>Estimated offset cost:</span> <span>$${estimatedCost.toLocaleString()}</span></div>
                    </div>
                    <p style="margin-top:1rem; font-size:0.7rem; color:var(--text-gray);">* Based on Tasmanian Biodiversity Offsets Policy (DPIPWE).</p>
                </div>
            `;
            showNotification('Offsets calculation complete', 'success');
        }

