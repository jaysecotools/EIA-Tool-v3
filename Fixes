You're right, let's just fix the map initialization issue. The problem is that Leaflet's map.invalidateSize() needs to be called after the map container is fully visible. Here's the specific fix - just replace your existing initMap function and add a resize observer:

Replace your current initMap function with this:

```javascript
function initMap() {
    if (mapInitialized) return;
    
    const container = document.getElementById('map-container');
    if (!container) {
        console.error('Map container not found');
        return;
    }
    
    // Check if container is visible
    if (container.offsetParent === null) {
        // Container is hidden, wait and retry
        setTimeout(initMap, 500);
        return;
    }
    
    try {
        // Default to Tasmania center
        const defaultLat = -42.0;
        const defaultLng = 146.5;
        
        // Force container to have a size
        container.style.height = '500px';
        container.style.width = '100%';
        container.style.display = 'block';
        
        map = L.map('map-container', {
            center: [defaultLat, defaultLng],
            zoom: 7,
            zoomControl: true
        });
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);
        
        // Click to drop marker
        map.on('click', function(e) {
            const lat = e.latlng.lat;
            const lng = e.latlng.lng;
            setMarker(lat, lng);
            reverseGeocode(lat, lng);
        });
        
        mapInitialized = true;
        
        // Force a resize after a moment to ensure proper rendering
        setTimeout(() => {
            if (map) {
                map.invalidateSize();
                console.log('Map size invalidated');
            }
        }, 300);
        
        // Also invalidate on window resize
        window.addEventListener('resize', function() {
            if (map) {
                map.invalidateSize();
            }
        });
        
        // Load saved marker from localStorage
        const savedMarker = localStorage.getItem('eia_map_marker');
        if (savedMarker) {
            try {
                const data = JSON.parse(savedMarker);
                if (data.lat && data.lng) {
                    setTimeout(() => {
                        setMarker(data.lat, data.lng);
                        if (data.address) {
                            markerAddress = data.address;
                            document.getElementById('address-display').textContent = data.address;
                        }
                        if (data.address) {
                            document.getElementById('location').value = data.address;
                        } else if (data.lat && data.lng) {
                            document.getElementById('location').value = `${data.lat}, ${data.lng}`;
                        }
                    }, 400);
                }
            } catch(e) {
                console.error('Error loading saved marker:', e);
            }
        }
        
        console.log('Map initialized successfully');
    } catch (e) {
        console.error('Error initializing map:', e);
    }
}
```

