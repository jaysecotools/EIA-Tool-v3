function ensureMapVisible() {
    if (!mapInitialized) {
        // Try to initialize the map
        initMap();
    } else if (map) {
        // If map exists but might be hidden, invalidate size
        setTimeout(() => {
            map.invalidateSize();
            console.log('Map size invalidated on card expand');
        }, 300);
    }
}
